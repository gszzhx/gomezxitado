-- Procura especificamente o botão "Peças" na interface
local function FindPartsButton()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end

    local partsTexts = {"Peças", "Peças", "Pecas", "peças", "pecas", "PARTES", "Partes", "partes"}
    
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            for _, descendant in ipairs(gui:GetDescendants()) do
                if descendant:IsA("TextButton") or descendant:IsA("ImageButton") then
                    local btnText = descendant.Text or ""
                    for _, partsText in ipairs(partsTexts) do
                        if btnText:find(partsText) then
                            print("🔧 Botão 'Peças' encontrado: " .. btnText)
                            return descendant
                        end
                    end
                end
                
                if descendant:IsA("TextLabel") then
                    local labelText = descendant.Text or ""
                    for _, partsText in ipairs(partsTexts) do
                        if labelText:find(partsText) then
                            local parent = descendant.Parent
                            while parent do
                                if parent:IsA("TextButton") or parent:IsA("ImageButton") then
                                    print("🔧 Botão 'Peças' encontrado via TextLabel: " .. labelText)
                                    return parent
                                end
                                parent = parent.Parent
                            end
                        end
                    end
                end
            end
        end
    end
    return nil
end

