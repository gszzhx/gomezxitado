-- Procura objetos que representam peças no mundo
local function FindPartsInWorld()
    local partsList = {}
    local character = LocalPlayer.Character
    if not character then return partsList end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return partsList end

    local partsKeywords = {"peça", "parts", "part", "peca", "component", "engrenagem", "gear", "item"}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        local isPart = false
        local objName = obj.Name:lower()

        for _, keyword in ipairs(partsKeywords) do
            if objName:find(keyword) then
                isPart = true
                break
            end
        end

        if isPart and (obj:IsA("Part") or obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("MeshPart")) then
            local position = nil
            if obj:IsA("Model") and obj.PrimaryPart then
                position = obj.PrimaryPart.Position
            elseif obj:IsA("BasePart") then
                position = obj.Position
            end

            if position then
                local distance = (position - humanoidRootPart.Position).Magnitude
                if distance < ClaimParts.collectRadius then
                    table.insert(partsList, obj)
                end
            end
        end
    end
    
    return partsList
end

-- Função para teleportar até a posição do botão/prompt
local function TeleportToPartsLocation(target)
    local character = LocalPlayer.Character
    if not character then return false end

    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end

    -- Se for um botão na GUI, não precisa teleportar
    if target:IsA("TextButton") or target:IsA("ImageButton") then
        return true
    end

    -- Se for um prompt, pega a posição do pai
    local targetPosition = nil
    local targetPart = target
    
    if target:IsA("ProximityPrompt") then
        targetPart = target.Parent
    end
    
    if targetPart:IsA("Model") and targetPart.PrimaryPart then
        targetPosition = targetPart.PrimaryPart.Position
    elseif targetPart:IsA("BasePart") then
        targetPosition = targetPart.Position
    end
    
    if not targetPosition then
        return false
    end

    -- Teleporta o jogador para perto do alvo
    local cframe = CFrame.new(
        targetPosition.X + math.random(-2, 2),
        targetPosition.Y + 2,
        targetPosition.Z + math.random(-2, 2)
    )
    
    humanoidRootPart.CFrame = cframe
    UpdateStatus(string.format("[Car Flipper] 📍 Teleportado para as peças"))
    task.wait(0.3)
    
    return true
end

-- Função principal de coleta de peças (COM INTERRUPÇÃO TOTAL)
local function CollectParts()
    if not ClaimParts.enabled then 
        return false 
    end
    
    -- Evita duplicação
    if ClaimParts.isCollecting then
        return false
    end
    
    ClaimParts.isCollecting = true
    
    -- INTERROMPE QUALQUER ATIVIDADE ATUAL
    if not InterruptionSystem:IsInterrupted() then
        local currentActivity = ActivityManager:GetCurrentActivity()
        InterruptionSystem:Interrupt("Coletar Peças", function()
            -- Callback para retomar
        end)
        UpdateStatus("[Car Flipper] 🔴 INTERROMPENDO todas as atividades para coletar peças...")
    end
    
    -- Pequena pausa para garantir que a interrupção foi processada
    task.wait(0.5)
    
    local success = false
    
    -- 1. PRIMEIRO: Procura o botão "Peças" na interface
    UpdateStatus("[Car Flipper] 🔧 Procurando botão 'Peças'...")
    local partsButton = FindPartsButton()
    if partsButton then
        UpdateStatus("[Car Flipper] 🔧 Botão 'Peças' encontrado! Coletando...")
        
        local clickSuccess = pcall(function()
            partsButton:Click()
            print("✅ Botão 'Peças' clicado com sucesso!")
        end)
        
        if clickSuccess then
            UpdateStatus("[Car Flipper] ✅ Peças coletadas via botão!")
            success = true
        end
    end

    -- 2. SEGUNDO: Procura o prompt "Peças" no mundo
    if not success then
        UpdateStatus("[Car Flipper] 🔧 Procurando prompt 'Peças'...")
        local partsPrompt = FindPartsPrompt()
        if partsPrompt then
            local teleported = TeleportToPartsLocation(partsPrompt)
            if teleported then
                UpdateStatus("[Car Flipper] 🔧 Coletando via prompt...")
                
                local promptSuccess = pcall(function()
                    if typeof(fireproximityprompt) == "function" then
                        fireproximityprompt(partsPrompt)
                    else
                        partsPrompt:InputHold()
                        task.wait(0.15)
                        partsPrompt:InputRelease()
                    end
                end)
                
                if promptSuccess then
                    UpdateStatus("[Car Flipper] ✅ Peças coletadas via prompt!")
                    success = true
                end
            end
        end
    end

    -- 3. TERCEIRO: Procura objetos de peças no mundo
    if not success then
        UpdateStatus("[Car Flipper] 🔧 Procurando objetos de peças...")
        local partsObjects = FindPartsInWorld()
        if #partsObjects > 0 then
            UpdateStatus(string.format("[Car Flipper] 🔧 Encontradas %d peças", #partsObjects))
            
            for _, partObj in ipairs(partsObjects) do
                if partObj and partObj.Parent then
                    local teleported = TeleportToPartsLocation(partObj)
                    if teleported then
                        local objectSuccess = pcall(function()
                            local clickDetector = partObj:FindFirstChild("ClickDetector")
                            if clickDetector then
                                clickDetector:Click()
                                print("✅ Peça coletada via ClickDetector")
                                return
                            end

                            local proximityPrompt = partObj:FindFirstChild("ProximityPrompt")
                            if proximityPrompt then
                                proximityPrompt:InputHold()
                                task.wait(0.1)
                                proximityPrompt:InputRelease()
                                print("✅ Peça coletada via ProximityPrompt")
                                return
                            end

                            local tool = partObj:FindFirstChild("Tool")
                            if tool then
                                local backpack = LocalPlayer:FindFirstChild("Backpack")
                                if backpack then
                                    tool.Parent = backpack
                                    print("✅ Peça coletada via Tool")
                                    return
                                end
                            end

                            if partObj:IsA("BasePart") then
                                local char = LocalPlayer.Character
                                if char and char:FindFirstChild("HumanoidRootPart") then
                                    firetouchinterest(char.HumanoidRootPart, partObj, 0)
                                    task.wait(0.1)
                                    firetouchinterest(char.HumanoidRootPart, partObj, 1)
                                    print("✅ Peça coletada via Touch")
                                    return
                                end
                            end
                        end)
                        
                        if objectSuccess then
                            UpdateStatus("[Car Flipper] ✅ Peça coletada!")
                            success = true
                            break
                        end
                    end
                end
            end
        end
    end

    if not success then
        UpdateStatus("[Car Flipper] ❌ Nenhuma peça encontrada...")
    end

    -- RESUME A ATIVIDADE ANTERIOR
    task.wait(0.3)
    if InterruptionSystem:IsInterrupted() then
        InterruptionSystem:Resume()
        UpdateStatus("[Car Flipper] 🔄 Atividade retomada!")
    end
    
    ClaimParts.isCollecting = false
    return success
end

-- Loop principal do Claim Parts (com interrupção total)
local function ClaimPartsLoop()
    while ClaimParts.enabled and ClaimParts.isRunning do
        -- Verifica se já está coletando para evitar duplicação
        if not ClaimParts.isCollecting then
            -- Tenta coletar as peças (com tentativas)
            local collectSuccess = false
            for attempt = 1, 3 do
                collectSuccess = CollectParts()
                if collectSuccess then 
                    break 
                end
                task.wait(0.5)
            end
        end

        -- Calcula e mostra o tempo até a próxima coleta
        local waitTime = ClaimParts.interval
        local minutes = math.floor(waitTime / 60)
        local seconds = waitTime % 60
        UpdateStatus(string.format("[Car Flipper] ⏱️ Próxima coleta de peças em %dm %ds", minutes, seconds))

        -- Aguarda o intervalo (1m42s)
        local startTime = tick()
        while ClaimParts.enabled and ClaimParts.isRunning and (tick() - startTime) < waitTime do
            task.wait(0.1)
        end
    end

    ClaimParts.isRunning = false
    if not ClaimParts.enabled then
        UpdateStatus("[Car Flipper] 🔧 Claim Parts parado")
    end
end

-- Inicia o Claim Parts
local function StartClaimParts()
    if ClaimParts.isRunning then return end
    if not ClaimParts.enabled then return end

    ClaimParts.isRunning = true
    UpdateStatus("[Car Flipper] 🔧 Claim Parts iniciado (1m42s)")

    ClaimParts.task = task.spawn(ClaimPartsLoop)
end

-- Para o Claim Parts
local function StopClaimParts()
    ClaimParts.enabled = false
    ClaimParts.isRunning = false
    ClaimParts.isCollecting = false

    if ClaimParts.task then
        task.cancel(ClaimParts.task)
        ClaimParts.task = nil
    end

    -- Restaura a atividade se estiver interrompida
    if InterruptionSystem:IsInterrupted() then
        InterruptionSystem:Resume()
    end

    UpdateStatus("[Car Flipper] 🔧 Claim Parts parado")
end

-- Alterna o Claim Parts
local function ToggleClaimParts()
    ClaimParts.enabled = not ClaimParts.enabled

    if ClaimParts.enabled then
        StartClaimParts()
    else
        StopClaimParts()
    end
end

