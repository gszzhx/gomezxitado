-- 5. SISTEMA DE GERENCIAMENTO DE ATIVIDADES
-- ═══════════════════════════════════════════════════════════════

local ActivityManager = {
    currentActivity = nil,
    activityQueue = {},
    isPaused = false,
    pausedActivity = nil,
}

function ActivityManager:SetActivity(activityName, activityFunction)
    if self.isPaused then
        -- Se estiver pausado, guarda para depois
        self.pausedActivity = {
            name = activityName,
            func = activityFunction
        }
        return
    end
    
    self.currentActivity = activityName
    UpdateStatus(string.format("[Car Flipper] 📌 Atividade: %s", activityName))
    
    -- Executa a atividade se for uma função
    if type(activityFunction) == "function" then
        activityFunction()
    end
end

function ActivityManager:Pause(activityName)
    if self.isPaused then return end
    
    self.isPaused = true
    self.pausedActivity = {
        name = self.currentActivity,
        func = nil
    }
    
    UpdateStatus(string.format("[Car Flipper] ⏸️ Atividade pausada para: %s", activityName))
end

function ActivityManager:Resume()
    if not self.isPaused then return end
    
    self.isPaused = false
    
    if self.pausedActivity then
        UpdateStatus(string.format("[Car Flipper] ▶️ Retomando: %s", self.pausedActivity.name))
        self.currentActivity = self.pausedActivity.name
        self.pausedActivity = nil
    else
        UpdateStatus("[Car Flipper] ▶️ Atividade retomada")
    end
end

function ActivityManager:IsPaused()
    return self.isPaused
end

function ActivityManager:GetCurrentActivity()
    return self.currentActivity
end

