-- 6. SISTEMA DE INTERRUPÇÃO (PRIORIDADE ABSOLUTA)
-- ═══════════════════════════════════════════════════════════════

local InterruptionSystem = {
    isInterrupted = false,
    interruptedTask = nil,
    resumeCallback = nil,
    priorityTasks = {},
}

-- Adiciona uma tarefa com prioridade
function InterruptionSystem:AddPriorityTask(taskName, taskFunction)
    self.priorityTasks[taskName] = taskFunction
end

-- Interrompe a atividade atual para executar uma tarefa prioritária
function InterruptionSystem:Interrupt(taskName, callback)
    if self.isInterrupted then
        return false
    end
    
    -- Pausa o gerenciador de atividades
    ActivityManager:Pause(taskName)
    
    self.isInterrupted = true
    self.interruptedTask = taskName
    self.resumeCallback = callback
    
    UpdateStatus(string.format("[Car Flipper] ⚠️ INTERROMPIDO: %s", taskName))
    return true
end

-- Resume a atividade após a interrupção
function InterruptionSystem:Resume()
    if not self.isInterrupted then
        return
    end
    
    self.isInterrupted = false
    local callback = self.resumeCallback
    self.resumeCallback = nil
    self.interruptedTask = nil
    
    -- Resume o gerenciador de atividades
    ActivityManager:Resume()
    
    if callback then
        UpdateStatus("[Car Flipper] 🔄 Retomando atividade...")
        callback()
    end
end

function InterruptionSystem:IsInterrupted()
    return self.isInterrupted
end

function InterruptionSystem:GetInterruptedTask()
    return self.interruptedTask
end

